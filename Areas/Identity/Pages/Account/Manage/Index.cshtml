@page
@model Denkiishi_v2.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = "Index";
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control" placeholder="Please choose your username." disabled />
                <label asp-for="Username" class="form-label"></label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Nickname" class="form-control" placeholder="Como quer ser chamado?" />
                <label asp-for="Input.Nickname" class="form-label">Nome de Exibição / Nickname</label>
                <span asp-validation-for="Input.Nickname" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Please enter your phone number." />
                <label asp-for="Input.PhoneNumber" class="form-label"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            @* Frequência SRS: valor numérico espelha notification_frequency_id / Denkiishi_v2.Enums.NotificationFrequency *@
            <div class="mb-3">
                <label asp-for="Input.NotificationFrequencyId" class="form-label"></label>
                <select asp-for="Input.NotificationFrequencyId" class="form-select" aria-describedby="freq-help">
                    <option value="0">Nunca</option>
                    <option value="1">Diariamente</option>
                    <option value="2">Duas vezes por semana</option>
                    <option value="3">Semanalmente</option>
                </select>
                <div id="freq-help" class="form-text">Controla com que frequência enviamos lembretes quando você tiver revisões SRS pendentes.</div>
                <span asp-validation-for="Input.NotificationFrequencyId" class="text-danger"></span>
            </div>

            <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary">Salvar</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}